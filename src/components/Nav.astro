---
import type { Release } from '../lib/github'

interface Props {
    activePage?: string
    release?: Release | null
}
const { activePage = '', release = null } = Astro.props

const fallback = 'https://github.com/modrexio/modrex/releases/latest'
const winUrl =
    release?.assets.find((a) => a.name.endsWith('.exe'))?.browser_download_url ?? fallback
const linUrl =
    release?.assets.find((a) => a.name.endsWith('.AppImage'))?.browser_download_url ?? fallback
---

<nav>
    <div class="wrap nav-inner">
        <a href="/" class="modrex-wordmark" style="font-size: 28px">MOD<span>REX</span></a>
        <div class="nav-links">
            <a href="/#screenshots">Screenshots</a>
            <a href="/#features">Features</a>
            <a href="/#download">Download</a>
            <a href="/docs/getting-started" class:list={[{ active: activePage === 'docs' }]}>Docs</a
            >
            <a href="https://github.com/modrexio/modrex" target="_blank" rel="noopener">GitHub</a>
            <a href="https://discord.gg/tenzpx8JRM" target="_blank" rel="noopener">Discord</a>
        </div>
        <div class="nav-right">
            <a
                id="nav-dl-btn"
                href={winUrl}
                data-win={winUrl}
                data-lin={linUrl}
                class="btn-lg primary nav-dl-btn"
                style="padding: 8px 16px; font-size: 13px"
            >
                Download
            </a>
        </div>
        <button
            class="hamburger"
            id="nav-hamburger"
            aria-label="Toggle navigation"
            aria-expanded="false"
        >
            <span></span>
            <span></span>
            <span></span>
        </button>
    </div>
    <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
        <div class="wrap mobile-links">
            <a href="/#screenshots">Screenshots</a>
            <a href="/#features">Features</a>
            <a href="/#download">Download</a>
            <a href="/docs/getting-started" class:list={[{ active: activePage === 'docs' }]}>Docs</a
            >
            <a href="https://github.com/modrexio/modrex" target="_blank" rel="noopener">GitHub</a>
            <a href="https://discord.gg/tenzpx8JRM" target="_blank" rel="noopener">Discord</a>
            <a
                id="mobile-dl-btn"
                href={winUrl}
                data-win={winUrl}
                data-lin={linUrl}
                class="btn-lg primary"
                style="justify-content: center; margin-top: 8px"
            >
                Download
            </a>
        </div>
    </div>
</nav>

<script>
    const navDlBtn = document.getElementById('nav-dl-btn') as HTMLAnchorElement | null
    const mobileDlBtn = document.getElementById('mobile-dl-btn') as HTMLAnchorElement | null
    const isMobile =
        /Android|iPhone|iPad|iPod/.test(navigator.userAgent) ||
        (navigator.maxTouchPoints > 1 && /Mac/.test(navigator.userAgent))
    const isLinux = /Linux|X11/.test(navigator.userAgent) && !/Android/.test(navigator.userAgent)
    if (!isMobile && isLinux) {
        if (navDlBtn) navDlBtn.href = navDlBtn.dataset.lin ?? navDlBtn.href
        if (mobileDlBtn) mobileDlBtn.href = mobileDlBtn.dataset.lin ?? mobileDlBtn.href
    }

    const hamburger = document.getElementById('nav-hamburger')
    const mobileMenu = document.getElementById('mobile-menu')
    hamburger?.addEventListener('click', () => {
        const open = mobileMenu?.classList.toggle('open')
        hamburger.setAttribute('aria-expanded', String(!!open))
        mobileMenu?.setAttribute('aria-hidden', String(!open))
    })
    mobileMenu?.querySelectorAll('a').forEach((a) =>
        a.addEventListener('click', () => {
            mobileMenu.classList.remove('open')
            hamburger?.setAttribute('aria-expanded', 'false')
            mobileMenu.setAttribute('aria-hidden', 'true')
        })
    )
</script>

<style>
    nav {
        position: sticky;
        top: 0;
        z-index: 40;
        background: color-mix(in srgb, var(--color-surface) 86%, transparent);
        backdrop-filter: blur(10px);
        border-bottom: 1px solid var(--color-border);
    }

    .nav-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 60px;
    }

    .nav-links {
        display: flex;
        align-items: center;
        gap: 28px;
    }

    .nav-links a {
        color: var(--text-secondary);
        font-size: 14px;
        text-decoration: none;
    }

    .nav-links a:hover,
    .nav-links a.active {
        color: var(--color-text);
    }

    .nav-right {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .hamburger {
        display: none;
        flex-direction: column;
        justify-content: center;
        gap: 5px;
        width: 36px;
        height: 36px;
        background: none;
        border: none;
        cursor: pointer;
        padding: 6px;
    }

    .hamburger span {
        display: block;
        width: 100%;
        height: 2px;
        background: var(--color-text);
        border-radius: 2px;
    }

    .mobile-menu {
        display: none;
    }

    .mobile-links {
        display: flex;
        flex-direction: column;
        padding-top: 8px;
        padding-bottom: 16px;
    }

    .mobile-links a:not(.btn-lg) {
        color: var(--text-secondary);
        font-size: 15px;
        text-decoration: none;
        padding: 12px 0;
        border-bottom: 1px solid var(--color-border);
    }

    .mobile-links a:not(.btn-lg):last-of-type {
        border-bottom: none;
    }

    .mobile-links a:not(.btn-lg):hover,
    .mobile-links a:not(.btn-lg).active {
        color: var(--color-text);
    }

    @media (max-width: 768px) {
        .nav-links,
        .nav-right {
            display: none;
        }

        .hamburger {
            display: flex;
        }

        .mobile-menu.open {
            display: block;
            border-top: 1px solid var(--color-border);
            background: var(--color-surface);
        }
    }
</style>
