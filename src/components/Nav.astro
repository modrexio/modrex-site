---
import type { Release } from '../lib/github'

interface Props {
    activePage?: string
    release?: Release | null
}
const { activePage = '', release = null } = Astro.props

const fallback = 'https://github.com/modrexio/modrex/releases/latest'
const winUrl =
    release?.assets.find((a) => a.name.endsWith('.exe'))?.browser_download_url ?? fallback
const linUrl =
    release?.assets.find((a) => a.name.endsWith('.AppImage'))?.browser_download_url ?? fallback
---

<nav>
    <div class="wrap nav-inner">
        <a href="/" class="modrex-wordmark" style="font-size: 28px">MOD<span>REX</span></a>
        <div class="nav-links">
            <a href="/#screenshots">Screenshots</a>
            <a href="/#features">Features</a>
            <a href="/#download">Download</a>
            <a href="/docs/" class:list={[{ active: activePage === 'docs' }]}>Docs</a>
        </div>
        <div class="nav-right">
            <a
                href="https://github.com/modrexio/modrex"
                class="social-link"
                target="_blank"
                rel="noopener"
                aria-label="GitHub"
                title="GitHub"
            >
                <span class="social-icon github" aria-hidden="true"></span>
            </a>
            <a
                href="https://discord.gg/tenzpx8JRM"
                class="social-link"
                target="_blank"
                rel="noopener"
                aria-label="Discord"
                title="Discord"
            >
                <span class="social-icon discord" aria-hidden="true"></span>
            </a>
            <a
                id="nav-dl-btn"
                href={winUrl}
                data-win={winUrl}
                data-lin={linUrl}
                class="btn-lg primary nav-dl-btn"
                style="padding: 8px 16px; font-size: 13px"
            >
                Download
            </a>
        </div>
        <button
            class="hamburger"
            id="nav-hamburger"
            aria-label="Toggle navigation"
            aria-expanded="false"
        >
            <span></span>
            <span></span>
            <span></span>
        </button>
    </div>
    <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
        <div class="wrap mobile-links">
            <a href="/#screenshots">Screenshots</a>
            <a href="/#features">Features</a>
            <a href="/#download">Download</a>
            <a href="/docs/" class:list={[{ active: activePage === 'docs' }]}>Docs</a>
            <div class="mobile-actions">
                <a
                    href="https://github.com/modrexio/modrex"
                    class="social-link"
                    target="_blank"
                    rel="noopener"
                    aria-label="GitHub"
                    title="GitHub"
                >
                    <span class="social-icon github" aria-hidden="true"></span>
                </a>
                <a
                    href="https://discord.gg/tenzpx8JRM"
                    class="social-link"
                    target="_blank"
                    rel="noopener"
                    aria-label="Discord"
                    title="Discord"
                >
                    <span class="social-icon discord" aria-hidden="true"></span>
                </a>
                <a
                    id="mobile-dl-btn"
                    href={winUrl}
                    data-win={winUrl}
                    data-lin={linUrl}
                    class="btn-lg primary mobile-dl-btn"
                >
                    Download
                </a>
            </div>
        </div>
    </div>
</nav>

<script>
    const navDlBtn = document.getElementById('nav-dl-btn') as HTMLAnchorElement | null
    const mobileDlBtn = document.getElementById('mobile-dl-btn') as HTMLAnchorElement | null
    const isMobile =
        /Android|iPhone|iPad|iPod/.test(navigator.userAgent) ||
        (navigator.maxTouchPoints > 1 && /Mac/.test(navigator.userAgent))
    const isLinux = /Linux|X11/.test(navigator.userAgent) && !/Android/.test(navigator.userAgent)
    if (!isMobile && isLinux) {
        if (navDlBtn) navDlBtn.href = navDlBtn.dataset.lin ?? navDlBtn.href
        if (mobileDlBtn) mobileDlBtn.href = mobileDlBtn.dataset.lin ?? mobileDlBtn.href
    }

    const hamburger = document.getElementById('nav-hamburger')
    const mobileMenu = document.getElementById('mobile-menu')
    hamburger?.addEventListener('click', () => {
        const open = mobileMenu?.classList.toggle('open')
        hamburger.setAttribute('aria-expanded', String(!!open))
        mobileMenu?.setAttribute('aria-hidden', String(!open))
    })
    mobileMenu?.querySelectorAll('a').forEach((a) =>
        a.addEventListener('click', () => {
            mobileMenu.classList.remove('open')
            hamburger?.setAttribute('aria-expanded', 'false')
            mobileMenu.setAttribute('aria-hidden', 'true')
        })
    )
</script>

<style>
    nav {
        position: sticky;
        top: 0;
        z-index: 40;
        background: color-mix(in srgb, var(--color-surface) 86%, transparent);
        backdrop-filter: blur(10px);
        border-bottom: 1px solid var(--color-border);
    }

    .nav-inner {
        --header-side-width: var(--sl-sidebar-width, 17rem);
        --header-wordmark-width: 5.5rem;

        display: grid;
        grid-template-columns: var(--header-side-width) minmax(0, 1fr) var(--header-side-width);
        align-items: center;
        height: 60px;
        width: 100%;
        max-width: none;
        margin: 0;
        padding: 0;
    }

    .modrex-wordmark {
        justify-self: center;
    }

    .nav-links {
        justify-self: center;
        display: flex;
        align-items: center;
        gap: clamp(12px, 2vw, 28px);
    }

    .nav-links a {
        color: var(--text-secondary);
        font-size: clamp(13px, 1.1vw, 14px);
        text-decoration: none;
        white-space: nowrap;
    }

    .nav-links a:hover,
    .nav-links a.active {
        color: var(--color-text);
    }

    .nav-right {
        justify-self: end;
        display: flex;
        align-items: center;
        gap: 8px;
        padding-inline-end: calc((var(--header-side-width) - var(--header-wordmark-width)) / 2);
    }

    .social-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 34px;
        height: 34px;
        flex: 0 0 34px;
        border-radius: var(--radius-sm);
        color: var(--color-text-muted);
        text-decoration: none;
        transition: var(--transition-colors);
    }

    .social-link:hover {
        color: var(--color-text);
        background: var(--color-surface-hover);
    }

    .social-link:focus-visible {
        outline: 2px solid var(--color-accent-bright);
        outline-offset: 2px;
    }

    .social-icon {
        display: block;
        width: 18px;
        height: 18px;
        background: currentColor;
        mask-position: center;
        mask-repeat: no-repeat;
        mask-size: contain;
        -webkit-mask-position: center;
        -webkit-mask-repeat: no-repeat;
        -webkit-mask-size: contain;
    }

    .social-icon.github {
        mask-image: url('/icons/github.svg');
        -webkit-mask-image: url('/icons/github.svg');
    }

    .social-icon.discord {
        mask-image: url('/icons/discord.svg');
        -webkit-mask-image: url('/icons/discord.svg');
    }

    .hamburger {
        display: none;
        flex-direction: column;
        justify-content: center;
        gap: 4px;
        width: 36px;
        height: 36px;
        background: none;
        border: none;
        cursor: pointer;
        padding: 10px;
    }

    .hamburger span {
        display: block;
        width: 100%;
        height: 2px;
        background: var(--color-text);
        border-radius: 2px;
    }

    .mobile-menu {
        display: none;
    }

    .mobile-links {
        display: flex;
        flex-direction: column;
        padding-top: 8px;
        padding-bottom: 16px;
    }

    .mobile-links > a:not(.btn-lg) {
        color: var(--text-secondary);
        font-size: 15px;
        text-decoration: none;
        padding: 12px 0;
        border-bottom: 1px solid var(--color-border);
    }

    .mobile-links > a:not(.btn-lg):last-of-type {
        border-bottom: none;
    }

    .mobile-links > a:not(.btn-lg):hover,
    .mobile-links > a:not(.btn-lg).active {
        color: var(--color-text);
    }

    .mobile-actions {
        display: flex;
        align-items: center;
        gap: 10px;
        padding-top: 14px;
    }

    .mobile-actions .social-link {
        width: 40px;
        height: 40px;
        flex-basis: 40px;
        background: var(--color-surface-hover);
        border: 1px solid var(--color-border);
    }

    .mobile-actions .social-link:hover {
        background: var(--color-surface-active);
    }

    .mobile-dl-btn {
        flex: 1;
    }

    @media (max-width: 50rem) {
        .nav-inner {
            display: flex;
            justify-content: space-between;
            padding-inline: 16px;
        }

        .nav-links,
        .nav-right {
            display: none;
        }

        .hamburger {
            display: flex;
        }

        .mobile-menu.open {
            display: block;
            border-top: 1px solid var(--color-border);
            background: var(--color-surface);
        }
    }
</style>
