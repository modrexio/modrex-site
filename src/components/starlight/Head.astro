---
import Default from '@astrojs/starlight/components/Head.astro'

// entry can be undefined for some Starlight page types (autogenerated section indexes)
const entry = Astro.props.entry as { data?: { title?: string } } | undefined
const entryTitle = entry?.data?.title ?? ''

const pathname = Astro.url.pathname.replace(/\/$/, '')
const segments = pathname.split('/').filter(Boolean)

// --- Breadcrumb ---

const SECTION_LABELS: Record<string, string> = {
    games: 'Games',
    concepts: 'Concepts',
}

const breadcrumbItems: Array<{ name: string; item?: string }> = [
    { name: 'Docs', item: new URL('/docs/', Astro.site).href },
]

if (segments.length === 2 && entryTitle) {
    breadcrumbItems.push({ name: entryTitle })
} else if (segments.length >= 3) {
    const section = segments[1]
    const sectionLabel = SECTION_LABELS[section]
    if (sectionLabel) {
        breadcrumbItems.push({
            name: sectionLabel,
            item: new URL(`/docs/${section}/`, Astro.site).href,
        })
    }
    if (entryTitle) {
        breadcrumbItems.push({ name: entryTitle })
    }
}

const emitBreadcrumb = breadcrumbItems.length >= 2

const breadcrumb = {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: breadcrumbItems.map((b, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        name: b.name,
        ...(b.item ? { item: b.item } : {}),
    })),
}

// --- HowTo (getting-started) ---

const isGettingStarted = pathname === '/docs/getting-started'

const howTo = {
    '@context': 'https://schema.org',
    '@type': 'HowTo',
    name: 'How to install Modrex mod manager',
    description:
        'Download Modrex and start managing mods for PAYDAY 3, PAYDAY 2, PAYDAY: The Heist, and Crime Boss: Rockay City.',
    step: [
        {
            '@type': 'HowToStep',
            position: '1',
            name: 'Download and install',
            text: 'Download the latest release from GitHub. On Windows, run the modrex_x86_64.exe installer. On Linux, install the .deb, .rpm, or .AppImage package for your distribution.',
        },
        {
            '@type': 'HowToStep',
            position: '2',
            name: 'Choose a game',
            text: 'On first launch Modrex asks which game to manage. Supported games: PAYDAY 3, PAYDAY 2, PAYDAY: The Heist, and Crime Boss: Rockay City.',
        },
        {
            '@type': 'HowToStep',
            position: '3',
            name: 'Set the game path',
            text: 'Modrex automatically scans for your game. If detection fails, open Settings, click Browse under Game Path, and select the game root folder.',
        },
        {
            '@type': 'HowToStep',
            position: '4',
            name: 'Configure launch options (PAYDAY 3)',
            text: 'For PAYDAY 3 pak mods to work, add -fileopenlog to Settings - Launch Options so Unreal Engine scans the ~mods folder.',
        },
    ],
}

// --- FAQPage (troubleshooting) ---

const isTroubleshooting = pathname === '/docs/troubleshooting'

const faqPage = {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
        {
            '@type': 'Question',
            name: 'Why are my mods not loading in PAYDAY 3?',
            acceptedAnswer: {
                '@type': 'Answer',
                text: 'The most common cause is a missing -fileopenlog launch argument. Add -fileopenlog to Settings - Launch Options. Without it, Unreal Engine 5 does not scan the ~mods folder and no pak mods will load.',
            },
        },
        {
            '@type': 'Question',
            name: "Modrex can't detect my game — what do I do?",
            acceptedAnswer: {
                '@type': 'Answer',
                text: "Go to Settings - Game Path and click Browse. Navigate to the game's installation root folder and click Select Folder. Modrex will validate and save the path.",
            },
        },
        {
            '@type': 'Question',
            name: "What does the 'Missing file' badge on a mod mean?",
            acceptedAnswer: {
                '@type': 'Answer',
                text: 'Modrex references a file or folder that no longer exists on disk, usually after manually deleting files or moving your game folder. Either Reinstall the mod or right-click and select Uninstall to remove the stale entry.',
            },
        },
        {
            '@type': 'Question',
            name: 'Modrex says it cannot install an archive — why?',
            acceptedAnswer: {
                '@type': 'Answer',
                text: "The archive likely belongs inside another mod or has a layout that does not identify a supported install target. Follow the author's instructions shown in the dialog, then install the files manually if needed.",
            },
        },
        {
            '@type': 'Question',
            name: "Modrex won't launch after a Windows update",
            acceptedAnswer: {
                '@type': 'Answer',
                text: 'Xbox Game Pass installs can lose their file permissions after major Windows updates. Run Modrex as administrator once to restore access, then relaunch normally.',
            },
        },
        {
            '@type': 'Question',
            name: 'Where is the Modrex log file?',
            acceptedAnswer: {
                '@type': 'Answer',
                text: 'On Windows: %APPDATA%\\Modrex\\logs\\modrex.log. On Linux: ~/.config/modrex/logs/modrex.log. You can also open it from Settings - Open log file.',
            },
        },
    ],
}
---

<Default {...Astro.props} />
{
    emitBreadcrumb && (
        <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumb)} />
    )
}
{
    isGettingStarted && (
        <script type="application/ld+json" is:inline set:html={JSON.stringify(howTo)} />
    )
}
{
    isTroubleshooting && (
        <script type="application/ld+json" is:inline set:html={JSON.stringify(faqPage)} />
    )
}
