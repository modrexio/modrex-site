---
import type { ModIndexStats } from '../lib/mod-index'

interface Props {
    indexStats: ModIndexStats | null
}

const { indexStats } = Astro.props
const supportedMods = indexStats
    ? new Intl.NumberFormat('en-US').format(indexStats.supportedMods)
    : null

const features: [string, string, string][] = [
    [
        'compass',
        'Browse modworkshop',
        'Search PAYDAY 3, PAYDAY 2, and PAYDAY: The Heist catalogs with categories, sorting, rich mod pages, and dependencies.',
    ],
    [
        'download',
        'One-click install',
        'Install, enable, disable, and remove in a click. Supports .pak, .zip, .7z, and .rar, with multi-file archives grouped as one.',
    ],
    [
        'folder-tree',
        'Organize in folders',
        'Sort your library into nested folders of any depth, with drag-and-drop reordering that sticks.',
    ],
    [
        'refresh-cw',
        'Smart updates',
        'Modrex detects out-of-date mods and lets you update them selectively - or all at once.',
    ],
    [
        'play',
        'Launch your way',
        'Boot modded or vanilla straight from the app. Vanilla launches hide your mods and restore them on exit.',
    ],
    [
        'crosshair',
        'Auto-detects your install',
        'Finds supported games across their launchers - and identifies manually placed mods by hash.',
    ],
]
---

<section id="features">
    <div class="wrap">
        <div class="sec-head">
            <h2 class="sec-title">Built for PAYDAY modding</h2>
            <p class="sec-sub">
                No more dragging files into game folders by hand. Modrex handles discovery, install,
                updates, and launch across supported PAYDAY games - so you can get back to the
                heist.
            </p>
        </div>
        {
            supportedMods && (
                <div class="index-count">
                    <strong>{supportedMods}</strong>
                    <span>supported mods indexed</span>
                </div>
            )
        }
        <div class="features-grid">
            {
                features.map(([icon, title, body]) => (
                    <div class="feature">
                        <div class="ic">
                            <i data-lucide={icon} />
                        </div>
                        <h3>{title}</h3>
                        <p>{body}</p>
                    </div>
                ))
            }
        </div>
    </div>
</section>

<script>
    import { createIcons, Compass, Download, FolderTree, RefreshCw, Play, Crosshair } from 'lucide'
    createIcons({ icons: { Compass, Download, FolderTree, RefreshCw, Play, Crosshair } })
</script>

<style>
    .features-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 16px;
    }

    .feature {
        grid-column: span 1;
        background: var(--color-surface-raised);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-lg);
        padding: 24px;
        transition: border-color var(--duration) var(--ease);
    }

    .feature:hover {
        border-color: var(--color-surface-light);
    }

    .feature:nth-child(-n + 2) {
        grid-column: span 2;
        background:
            linear-gradient(135deg, var(--accent-tint-10), transparent 48%),
            var(--color-surface-raised);
    }

    .ic {
        width: 40px;
        height: 40px;
        border-radius: var(--radius-md);
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--accent-tint-10);
        color: var(--color-accent-bright);
        border: 1px solid var(--accent-tint-30);
    }

    .feature h3 {
        font-size: 16px;
        font-weight: 600;
        margin: 16px 0 6px;
    }

    .feature p {
        font-size: 14px;
        line-height: 1.55;
        color: var(--text-secondary);
        margin: 0;
    }

    .index-count {
        width: 100%;
        display: flex;
        align-items: baseline;
        justify-content: center;
        gap: 10px;
        margin: -24px 0 48px;
        padding: 18px 0;
        border-top: 1px solid var(--color-border);
        border-bottom: 1px solid var(--color-border);
        font-size: 14px;
        font-weight: 600;
        color: var(--text-secondary);
    }

    .index-count strong {
        font-family: var(--font-display);
        font-size: 28px;
        line-height: 1;
        letter-spacing: 0.01em;
        color: var(--color-text);
        vertical-align: -0.08em;
    }

    @media (max-width: 500px) {
        .index-count {
            margin: -16px 0 36px;
            flex-direction: column;
            align-items: center;
            gap: 4px;
        }
    }

    @media (max-width: 860px) {
        .features-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .feature,
        .feature:nth-child(-n + 2) {
            grid-column: span 1;
        }
    }

    @media (max-width: 500px) {
        .features-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
