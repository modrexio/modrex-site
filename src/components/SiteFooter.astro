---

<footer>
    <div class="wrap footer-inner">
        <div>
            <a href="/" class="modrex-wordmark" style="font-size: 20px">MOD<span>REX</span></a>
            <p class="legal">
                A free, open-source desktop mod manager powered by modworkshop. Not affiliated with
                any game studio or publisher.
            </p>
        </div>
        <div class="links">
            <a href="https://github.com/modrexio/modrex" target="_blank" rel="noopener">GitHub</a>
            <a href="/docs/getting-started">Docs</a>
            <a href="https://modworkshop.net/g/payday-3" target="_blank" rel="noopener"
                >modworkshop</a
            >
            <a href="https://github.com/modrexio/modrex/issues" target="_blank" rel="noopener"
                >Report a bug</a
            >
        </div>
    </div>
</footer>

<style>
    footer {
        padding: 48px 0;
        border-top: 1px solid var(--color-border);
    }

    .footer-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 24px;
    }

    .legal {
        font-size: 12px;
        color: var(--text-tertiary);
        max-width: 420px;
        margin: 10px 0 0;
    }

    .links {
        display: flex;
        gap: 24px;
        flex-wrap: wrap;
    }

    .links a {
        font-size: 14px;
        color: var(--text-secondary);
        text-decoration: none;
    }

    .links a:hover {
        color: var(--color-text);
    }
</style>
