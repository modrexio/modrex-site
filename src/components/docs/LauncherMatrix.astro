---
import { allLaunchers, docsGames } from '../../data/docsGames'
import SupportBadge from './SupportBadge.astro'
---

<table class="docs-data-table">
    <thead>
        <tr>
            <th>Game</th>
            {allLaunchers.map((launcher) => <th>{launcher}</th>)}
        </tr>
    </thead>
    <tbody>
        {
            docsGames.map((game) => (
                <tr>
                    <td>{game.name}</td>
                    {allLaunchers.map((launcher) => (
                        <td>
                            <SupportBadge supported={game.launchers.includes(launcher)} />
                        </td>
                    ))}
                </tr>
            ))
        }
    </tbody>
</table>
