---
interface Props {
    os: 'Windows' | 'Linux'
}

const { os } = Astro.props

const icons: Record<Props['os'], string> = {
    Windows: 'windows-white',
    Linux: 'linux-white',
}
---

<img class="docs-os-icon" src={`/icons/${icons[os]}.svg`} alt="" />

<style>
    .docs-os-icon {
        display: inline-block;
        width: 0.85em;
        height: 0.85em;
        vertical-align: -0.05em;
        margin-inline-end: 0.3em;
    }
</style>
