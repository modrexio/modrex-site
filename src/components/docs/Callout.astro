---
interface Props {
    type?: 'info' | 'warning'
}
const { type = 'info' } = Astro.props
---

<div class:list={['callout', `callout--${type}`]}>
    <span class="ci">
        {
            type === 'warning' ? (
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                >
                    <path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z" />
                    <line x1="12" y1="9" x2="12" y2="13" />
                    <line x1="12" y1="17" x2="12.01" y2="17" />
                </svg>
            ) : (
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                >
                    <circle cx="12" cy="12" r="10" />
                    <line x1="12" y1="16" x2="12" y2="12" />
                    <line x1="12" y1="8" x2="12.01" y2="8" />
                </svg>
            )
        }
    </span>
    <div class="callout-body">
        <slot />
    </div>
</div>

<style>
    .callout {
        display: flex;
        gap: 12px;
        background: var(--accent-tint-10);
        border: 1px solid var(--accent-tint-30);
        border-radius: var(--radius-lg);
        padding: 14px 16px;
        margin: 0 0 18px;
    }

    .callout--warning {
        background: var(--warning-tint-10);
        border-color: var(--warning-tint-30);
    }

    .ci {
        color: var(--color-accent-bright);
        flex-shrink: 0;
        margin-top: 1px;
        display: flex;
    }

    .callout--warning .ci {
        color: var(--color-warning);
    }

    .callout-body {
        font-size: 14px;
        color: var(--text-secondary);
    }

    .callout-body :global(p) {
        margin: 0;
        font-size: 14px;
    }

    .callout-body :global(strong),
    .callout-body :global(b) {
        color: var(--color-text);
    }
</style>
