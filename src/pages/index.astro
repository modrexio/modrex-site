---
import BaseLayout from '../layouts/BaseLayout.astro'
import Nav from '../components/Nav.astro'
import Hero from '../components/Hero.astro'
import Features from '../components/Features.astro'
import DownloadSection from '../components/DownloadSection.astro'
import Changelog from '../components/Changelog.astro'
import SiteFooter from '../components/SiteFooter.astro'
import { getLatestRelease, getRecentReleases } from '../lib/github'
import type { Release } from '../lib/github'
import { getModIndexStats } from '../lib/mod-index'
import type { ModIndexStats } from '../lib/mod-index'

let release: Release | null = null
try {
    release = await getLatestRelease()
} catch {
    // GitHub API unavailable at build time — release data optional
}

let recentReleases: Release[] = []
try {
    recentReleases = await getRecentReleases(3)
} catch {
    // GitHub API unavailable at build time - the changelog section renders nothing
}

let indexStats: ModIndexStats | null = null
try {
    indexStats = await getModIndexStats()
} catch (error) {
    console.error('Failed to load mod index stats', error)
}

const jsonLd = {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'Modrex',
    description:
        'Free, open-source mod manager for PAYDAY 3, PAYDAY 2, PAYDAY: The Heist, and Crime Boss: Rockay City. Browse modworkshop, install mods in one click, and launch modded games from the app.',
    operatingSystem: ['Windows', 'Linux'],
    applicationCategory: 'GameApplication',
    offers: {
        '@type': 'Offer',
        price: '0',
        priceCurrency: 'USD',
    },
    url: 'https://modrex.net',
    downloadUrl: 'https://github.com/modrexio/modrex/releases/latest',
    softwareVersion: release?.tag_name?.replace(/^v/, '') ?? undefined,
}
---

<BaseLayout
    title="Modrex"
    description="Free, open-source mod manager for PAYDAY 3, PAYDAY 2, PAYDAY: The Heist, and Crime Boss. One-click mods from modworkshop."
    ogImage={new URL('/Browse%20Mods%20Window.png', Astro.site).href}
    ogImageWidth={2560}
    ogImageHeight={1368}
>
    <link rel="preload" as="image" href="/Game%20Picker%20Window.png" slot="head" />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} slot="head" />
    <Nav release={release} />
    <Hero release={release} />
    <Features indexStats={indexStats} />
    <DownloadSection release={release} />
    <Changelog releases={recentReleases} />
    <SiteFooter />
</BaseLayout>
