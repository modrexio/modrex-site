{
    "name": "modrex-site",
    "type": "module",
    "version": "0.0.1",
    "scripts": {
        "dev": "astro dev",
        "build": "astro build",
        "preview": "astro preview",
        "typecheck": "astro check",
        "typecheck:functions": "tsc -p functions/tsconfig.json",
        "test": "vitest",
        "test:run": "vitest run",
        "lint": "eslint src/",
        "lint:fix": "eslint src/ --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "prepare": "husky"
    },
    "lint-staged": {
        "*.{js,mjs,ts,tsx,astro}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{css,json,md,mdx}": [
            "prettier --write"
        ]
    },
    "devDependencies": {
        "@astrojs/check": "^0.9.9",
        "@astrojs/mdx": "^6.0.2",
        "@commitlint/cli": "^21.0.2",
        "@commitlint/config-conventional": "^21.0.2",
        "@commitlint/types": "^21.0.1",
        "@eslint/js": "^10.0.1",
        "@tailwindcss/vite": "^4.3.0",
        "astro": "^6.4.5",
        "eslint": "^10.4.1",
        "eslint-plugin-astro": "^1.7.0",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.7",
        "marked": "^18.0.5",
        "prettier": "^3.8.3",
        "prettier-plugin-astro": "^0.14.1",
        "tailwindcss": "^4.3.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.60.1",
        "vitest": "^4.1.10",
        "zod": "^4.4.3"
    },
    "dependencies": {
        "@astrojs/sitemap": "^3.7.3",
        "@astrojs/starlight": "^0.40.0",
        "lucide": "^1.17.0"
    }
}
